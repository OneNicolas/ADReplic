<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Thème sombre : fond sombre, texte clair, mêmes accents bleus.
         Palette inspirée de GitHub dark : ni noir pur ni saturé. -->

    <SolidColorBrush x:Key="Accent"        Color="#3B82F6" />
    <SolidColorBrush x:Key="AccentHover"   Color="#60A5FA" />
    <SolidColorBrush x:Key="AccentPressed" Color="#2563EB" />

    <SolidColorBrush x:Key="Surface"        Color="#0D1117" />
    <SolidColorBrush x:Key="SurfaceAlt"     Color="#161B22" />
    <SolidColorBrush x:Key="SurfaceElevated" Color="#1C232C" />

    <SolidColorBrush x:Key="Foreground"    Color="#E6EDF3" />
    <SolidColorBrush x:Key="SubtleText"    Color="#8B949E" />

    <SolidColorBrush x:Key="Border"        Color="#30363D" />
    <SolidColorBrush x:Key="BorderStrong"  Color="#484F58" />

    <!-- Versions plus claires des sémantiques pour le contraste sur fond sombre -->
    <SolidColorBrush x:Key="Success"       Color="#3FB950" />
    <SolidColorBrush x:Key="Warning"       Color="#D29922" />
    <SolidColorBrush x:Key="Danger"        Color="#F85149" />

    <SolidColorBrush x:Key="RowHover"      Color="#21262D" />
    <SolidColorBrush x:Key="RowSelected"   Color="#1F3A5F" />

</ResourceDictionary>
