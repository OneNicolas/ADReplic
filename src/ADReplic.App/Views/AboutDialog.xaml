<Window x:Class="ADReplic.App.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="À propos d'ADReplic"
        Width="460" Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Surface}">
    <Border Padding="28,24" Background="{DynamicResource SurfaceElevated}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Logo + nom -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                <Image Source="{StaticResource AppIcon}" Width="64" Height="64" />
            </StackPanel>

            <TextBlock Grid.Row="1" Text="ADReplic" FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource Foreground}"
                       HorizontalAlignment="Center" Margin="0,0,0,4" />

            <TextBlock Grid.Row="2" x:Name="VersionText" FontSize="13"
                       Foreground="{DynamicResource SubtleText}"
                       HorizontalAlignment="Center" Margin="0,0,0,16" />

            <TextBlock Grid.Row="3" TextWrapping="Wrap"
                       Foreground="{DynamicResource Foreground}" FontSize="12"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       LineHeight="18" Margin="0,0,0,8">
                <Run Text="Outil portable d'audit de la réplication Active Directory." />
                <LineBreak />
                <Run Text="Remplaçant léger d'Active Directory Replication Status Tool." />
                <LineBreak /><LineBreak />
                <Run Text="Développé par Nicolas Haultcoeur — Scopi" Foreground="{DynamicResource SubtleText}" />
                <LineBreak />
                <Run Text=".NET Framework 4.8 · WPF · System.DirectoryServices" Foreground="{DynamicResource SubtleText}" />
            </TextBlock>

            <Button Grid.Row="5" Content="Fermer" Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Center" Padding="32,8" IsDefault="True" IsCancel="True"
                    Click="OnCloseClick" />
        </Grid>
    </Border>
</Window>
