<Window x:Class="ADReplic.App.Views.CredentialsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Identifiants alternatifs"
        Width="460" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Surface}">
    <Border Padding="24,20" Background="{DynamicResource SurfaceElevated}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Identifiants alternatifs"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource Foreground}" Margin="0,0,0,4" />

            <TextBlock Grid.Row="1" Text="Pour interroger une forêt distante ou utiliser un autre compte."
                       Foreground="{DynamicResource SubtleText}" FontSize="12" Margin="0,0,0,18" />

            <TextBlock Grid.Row="2" Text="Utilisateur" FontWeight="SemiBold"
                       Foreground="{DynamicResource SubtleText}" FontSize="12" Margin="0,0,0,6" />
            <TextBox   Grid.Row="3" x:Name="UserBox" Margin="0,0,0,6" />

            <TextBlock Grid.Row="4" FontSize="11" Foreground="{DynamicResource SubtleText}" Margin="0,0,0,16"
                       TextWrapping="Wrap"
                       Text="Format : DOMAINE\compte ou user@domaine.complet. Le suffixe UPN doit correspondre au domaine cible, pas forcément au suffixe email." />

            <TextBlock Grid.Row="5" Text="Mot de passe" FontWeight="SemiBold"
                       Foreground="{DynamicResource SubtleText}" FontSize="12" Margin="0,0,0,6" />
            <PasswordBox Grid.Row="6" x:Name="PassBox" VerticalAlignment="Top" />

            <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Effacer" Margin="0,0,8,0" Click="OnClearClick" />
                <Button Content="Annuler" Margin="0,0,8,0" IsCancel="True" />
                <Button Content="OK"      Style="{StaticResource PrimaryButton}"
                        IsDefault="True"  Click="OnOkClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
